---
// Decorative consumer-choice tangency (budget line + indifference curve)
// for the course hero. Same graph-paper frame as the other course heroes.
---
<svg class="hero-diagram" viewBox="0 0 230 178" fill="none" aria-hidden="true">
  <g stroke="#ece6db" stroke-width="1">
    <path d="M58 18 V146 M88 18 V146 M118 18 V146 M148 18 V146 M178 18 V146 M208 18 V146"/>
    <path d="M28 44 H214 M28 70 H214 M28 96 H214 M28 122 H214"/>
  </g>
  <!-- axes -->
  <path d="M28 12 V146 H214" stroke="#221d16" stroke-width="1.8" stroke-linecap="round"/>
  <!-- budget line -->
  <path class="draw" d="M40 32 L196 138" stroke="#3a3a3a" stroke-width="2.4" stroke-linecap="round"/>
  <!-- indifference curve, tangent at the optimum -->
  <path class="draw d2" d="M72 20 C 78 48, 106 76.9, 118 85 C 134 95.9, 160 103, 204 110" stroke="#5A1BA6" stroke-width="3" stroke-linecap="round"/>
  <!-- guide lines to the optimum -->
  <path d="M118 85 V146 M28 85 H118" stroke="#9CAF88" stroke-width="1.4" stroke-dasharray="3 4"/>
  <circle cx="118" cy="85" r="4.5" fill="#A03A2C" stroke="#FAF7F2" stroke-width="2"/>
  <!-- labels -->
  <text x="14" y="89" font-family="'STIX Two Text',serif" font-style="italic" font-size="12" fill="#6b6358">y*</text>
  <text x="113" y="160" font-family="'STIX Two Text',serif" font-style="italic" font-size="12" fill="#6b6358">x*</text>
  <text x="16" y="14" font-family="'STIX Two Text',serif" font-style="italic" font-size="12" fill="#6b6358">y</text>
  <text x="218" y="160" font-family="'STIX Two Text',serif" font-style="italic" font-size="12" fill="#6b6358">x</text>
  <text x="207" y="121" font-family="'STIX Two Text',serif" font-style="italic" font-size="11" fill="#5A1BA6">u*</text>
</svg>
