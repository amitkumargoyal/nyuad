---
import Course from '../../../layouts/Course.astro';
import { getCollection, render } from 'astro:content';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const entries = await getCollection('micro_notes', ({ data }) => !data.draft);
  return entries.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Course
  title={`${note.data.title} — Microeconomics, NYUAD`}
  eyebrow="Microeconomics · Notes"
  heading={note.data.title}
  article
  backlinkHref={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/microeconomics/`}
  backlinkLabel="← Back to Microeconomics"
>
  <div class="article-meta">{fmtDate(note.data.date)}</div>
  <div class="article">
    <Content />
  </div>
</Course>
