---
import Course from '../layouts/Course.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const courses = [
  {
    slug: 'markets',
    title: 'Markets',
    desc: 'Interactive tools, lecture notes, and exercises covering supply and demand, equilibrium, and welfare analysis.',
  },
  {
    slug: 'game-theory',
    title: 'Game Theory',
    desc: 'Interactive tools, lecture notes, and problem sets on strategic interaction, equilibrium concepts, and the design of incentives.',
  },
  {
    slug: 'microeconomics',
    title: 'Microeconomics',
    desc: 'Interactive tools, lecture notes, and problem sets on consumer theory, producer theory, and the behaviour of markets.',
  },
];
---
<Course
  title="Amit Goyal — NYU Abu Dhabi"
  eyebrow="NYU Abu Dhabi"
  heading="Amit Goyal"
  lede="Materials for courses."
>
  <section class="section">
    <div class="section-head">
      <h2 class="section-title">Courses</h2>
      <div class="section-rule"></div>
      <div class="section-note">{courses.length} courses</div>
    </div>
    <div class="tools-grid">
      {courses.map((c) => (
        <a class="tool card-plain" href={`${base}/${c.slug}/`}>
          <div>
            <div class="tool-tag">Course</div>
            <div class="tool-title">{c.title}</div>
            <div class="tool-desc">{c.desc}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Course>
